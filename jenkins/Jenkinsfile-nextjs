pipeline {

    agent any

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/sample/repo.git'
            }
        }

        stage('Install') {
            steps {
                sh 'npm install'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }
    }
}
